# =========================================================================
# Sample .env — copy to `.env` and fill in your own values.
# Anything secret (private keys, API keys) goes here and is git-ignored.
# =========================================================================

# RPC endpoint for Sepolia. Free providers: Infura, Alchemy, Ankr, public-node.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key of the deployer account on Sepolia. MUST be funded with Sepolia
# ETH (use a faucet). Burner-only — never reuse a mainnet key here.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional: Etherscan API key, used by `forge script --verify`.
ETHERSCAN_API_KEY=

# =========================================================================
# Adapter targets (overridable; defaults baked into the deploy script)
# =========================================================================

# Aave V3 Pool address on Sepolia
AAVE_V3_POOL=0x6Ae43d3271ff6888e7Fc43Fd7321a503ff738951

# Balancer V2 Vault — same address on every network it ships to
BALANCER_VAULT=0xBA12222222228d8Ba445958a75a0704d566BF2C8
